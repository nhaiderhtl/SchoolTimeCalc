@using SchoolTimeCalc.Models
@using SchoolTimeCalc.Services
@inject ICalculationService CalculationService
@inject MockAuthService AuthService
@rendermode InteractiveServer

@if (loading)
{
    <div class="space-y-4">
        <div class="animate-pulse bg-gray-200 rounded h-10 w-full"></div>
        <div class="animate-pulse bg-gray-200 rounded h-10 w-full"></div>
        <div class="animate-pulse bg-gray-200 rounded h-10 w-full"></div>
    </div>
}
else if (result != null && result.SubjectLessons.Any())
{
    <div class="space-y-6">
        @foreach (var subject in result.SubjectLessons.OrderByDescending(s => s.TotalLessons))
        {
            var percentage = subject.TotalLessons > 0 ? Math.Round((double)subject.CompletedLessons / subject.TotalLessons * 100, 1) : 0;
            
            <div class="w-full">
                <div class="flex justify-between items-center mb-1">
                    <span class="text-sm font-semibold text-gray-800">@subject.SubjectName</span>
                    <div class="text-xs text-gray-600">
                        <span class="font-bold text-gray-900">@subject.CompletedLessons / @subject.TotalLessons</span>
                        <span class="ml-2 text-gray-500">(@subject.RemainingLessons left)</span>
                    </div>
                </div>
                
                <div class="w-full bg-gray-200 rounded-full h-3 flex overflow-hidden">
                    <div class="bg-emerald-500 h-3" style="width: @percentage%"></div>
                    @if (subject.CanceledLessons > 0)
                    {
                        var canceledPercentage = Math.Round((double)subject.CanceledLessons / subject.TotalLessons * 100, 1);
                        <div class="bg-red-400 h-3" style="width: @canceledPercentage%" title="@subject.CanceledLessons canceled lessons"></div>
                    }
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-4 text-gray-500 text-sm">
        No subject data available.
    </div>
}

@code {
    private bool loading = true;
    private CalculationResult? result;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user != null && !string.IsNullOrEmpty(user.Username))
            {
                result = await CalculationService.CalculateRemainingTimeAsync(user.Username);
            }
        }
        catch 
        {
            result = null;
        }
        finally
        {
            loading = false;
        }
    }
}
