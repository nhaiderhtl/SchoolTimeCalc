@using SchoolTimeCalc.Models
@using SchoolTimeCalc.Services
@inject ICalculationService CalculationService
@inject MockAuthService AuthService
@attribute [Microsoft.AspNetCore.Components.StreamRendering]

<div class="bg-white rounded-lg shadow-md p-4 mt-6">
    <div class="flex justify-between items-center mb-4">
        <h2 class="text-lg font-bold text-gray-800">Week View Calendar</h2>
        <div class="flex space-x-2">
            <button class="px-3 py-1 bg-gray-200 text-gray-700 rounded hover:bg-gray-300" @onclick="PreviousWeek">&lt; Prev</button>
            <span class="px-3 py-1 font-medium text-gray-800">@currentWeekStart.ToString("MMM dd") - @currentWeekEnd.ToString("MMM dd")</span>
            <button class="px-3 py-1 bg-gray-200 text-gray-700 rounded hover:bg-gray-300" @onclick="NextWeek">Next &gt;</button>
        </div>
    </div>

    @if (isLoading)
    {
        <p class="text-gray-500">Loading timetable...</p>
    }
    else if (weekData == null)
    {
        <p class="text-red-500">Failed to load data.</p>
    }
    else
    {
        <div class="overflow-x-auto">
            <div class="min-w-[800px] border border-gray-200 rounded">
                <div class="grid grid-cols-6 border-b border-gray-200 bg-gray-50">
                    <div class="p-3 font-semibold text-center border-r border-gray-200 text-gray-600">Time</div>
                    @for (int i = 0; i < 5; i++)
                    {
                        var day = currentWeekStart.AddDays(i);
                        <div class="p-3 font-semibold text-center border-r border-gray-200 @GetHeaderClass(day)">
                            @day.ToString("ddd, MMM dd")
                        </div>
                    }
                </div>

                <div class="relative min-h-[400px]">
                    @foreach (var timeslot in timeslots)
                    {
                        var topStr = GetTopPosition(timeslot) + "%";
                        <div class="absolute w-full border-t border-gray-100 flex" style="top: @topStr;">
                            <div class="w-1/6 text-xs text-gray-400 text-center -mt-2 bg-white pr-2 z-10">
                                @timeslot.ToString(@"hh\:mm")
                            </div>
                        </div>
                    }

                    <div class="grid grid-cols-6 h-full absolute inset-0">
                        <div class="border-r border-gray-200 z-0 relative pointer-events-none"></div>
                        @for (int i = 0; i < 5; i++)
                        {
                            var day = currentWeekStart.AddDays(i);
                            <div class="border-r border-gray-200 z-0 relative">
                                @if (IsHoliday(day))
                                {
                                    <div class="absolute inset-0 bg-red-50 opacity-80 flex items-center justify-center pointer-events-none z-10">
                                        <span class="text-red-600 font-bold rotate-[-45deg] whitespace-nowrap opacity-50">HOLIDAY</span>
                                    </div>
                                }
                                @foreach (var lesson in GetLessonsForDay(day))
                                {
                                    <div class="absolute left-1 right-1 rounded p-1 text-xs @GetLessonClass(lesson)"
                                         style="top: @GetTopPosition(lesson.StartTime)%; height: @GetHeight(lesson.StartTime, lesson.EndTime)%; z-index: 20;">
                                        <div class="font-semibold truncate">@lesson.SubjectName</div>
                                        <div>@lesson.StartTime.ToString(@"hh\:mm") - @lesson.EndTime.ToString(@"hh\:mm")</div>
                                        @if (lesson.IsCanceled)
                                        {
                                            <div class="text-red-700 font-bold mt-1">CANCELED</div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isLoading = true;
    private WeekViewData? weekData;
    private DateTime currentWeekStart;
    private DateTime currentWeekEnd;
    
    // Configurable business hours
    private TimeSpan minTime = new TimeSpan(7, 30, 0); // 7:30
    private TimeSpan maxTime = new TimeSpan(17, 30, 0); // 17:30
    private List<TimeSpan> timeslots = new();

    protected override async Task OnInitializedAsync()
    {
        var today = DateTime.Today;
        int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
        currentWeekStart = today.AddDays(-1 * diff).Date;
        currentWeekEnd = currentWeekStart.AddDays(4).Date;

        for (int h = minTime.Hours; h <= maxTime.Hours; h++)
        {
            timeslots.Add(new TimeSpan(h, 0, 0));
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user != null)
            {
                weekData = await CalculationService.GetWeekTimetableAsync(user.Username, currentWeekStart);
                if (weekData != null && weekData.Lessons.Any())
                {
                    // Adjust max time based on actual lessons
                    var latest = weekData.Lessons.Max(l => l.EndTime);
                    if (latest > maxTime)
                    {
                        maxTime = new TimeSpan(latest.Hours + 1, 0, 0);
                        timeslots.Clear();
                        for (int h = minTime.Hours; h <= maxTime.Hours; h++)
                        {
                            timeslots.Add(new TimeSpan(h, 0, 0));
                        }
                    }
                }
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task PreviousWeek()
    {
        currentWeekStart = currentWeekStart.AddDays(-7);
        currentWeekEnd = currentWeekStart.AddDays(4);
        await LoadDataAsync();
    }

    private async Task NextWeek()
    {
        currentWeekStart = currentWeekStart.AddDays(7);
        currentWeekEnd = currentWeekStart.AddDays(4);
        await LoadDataAsync();
    }

    private IEnumerable<WeekLesson> GetLessonsForDay(DateTime day)
    {
        if (weekData == null) return Enumerable.Empty<WeekLesson>();
        return weekData.Lessons.Where(l => l.Date.Date == day.Date);
    }

    private bool IsHoliday(DateTime day)
    {
        if (weekData == null) return false;
        return weekData.Holidays.Any(h => day >= h.StartDate && day <= h.EndDate);
    }

    private string GetHeaderClass(DateTime day)
    {
        return IsHoliday(day) ? "bg-red-50 text-red-700" : "text-gray-600";
    }

    private string GetLessonClass(WeekLesson lesson)
    {
        if (lesson.IsCanceled) return "bg-red-100 border-l-4 border-red-500 text-red-800 line-through opacity-70";
        return "bg-blue-100 border-l-4 border-blue-500 text-blue-800 shadow-sm";
    }

    private double GetTopPosition(TimeSpan time)
    {
        var totalMinutes = (maxTime - minTime).TotalMinutes;
        var diffMinutes = (time - minTime).TotalMinutes;
        if (diffMinutes < 0) return 0;
        return (diffMinutes / totalMinutes) * 100;
    }

    private double GetHeight(TimeSpan start, TimeSpan end)
    {
        var totalMinutes = (maxTime - minTime).TotalMinutes;
        var duration = (end - start).TotalMinutes;
        return (duration / totalMinutes) * 100;
    }
}
