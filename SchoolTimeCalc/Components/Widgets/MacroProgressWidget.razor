@using SchoolTimeCalc.Models
@using SchoolTimeCalc.Services
@inject ICalculationService CalculationService
@inject MockAuthService AuthService
@rendermode InteractiveServer

@if (loading)
{
    <div class="animate-pulse bg-gray-200 rounded-lg h-32 w-full"></div>
}
else if (result != null && (result.TotalRemainingDays > 0 || result.TotalRemainingLessons > 0))
{
    <div class="grid grid-cols-2 gap-4 md:gap-6 w-full">
        <div class="bg-blue-50 p-6 rounded-xl shadow-sm border border-blue-100 flex flex-col items-center justify-center text-center">
            <span class="text-blue-600 text-xs md:text-sm font-semibold uppercase tracking-wider mb-1">Remaining Days</span>
            <span class="text-4xl md:text-5xl font-black text-blue-900">@result.TotalRemainingDays</span>
        </div>
        <div class="bg-indigo-50 p-6 rounded-xl shadow-sm border border-indigo-100 flex flex-col items-center justify-center text-center">
            <span class="text-indigo-600 text-xs md:text-sm font-semibold uppercase tracking-wider mb-1">Remaining Lessons</span>
            <span class="text-4xl md:text-5xl font-black text-indigo-900">@result.TotalRemainingLessons</span>
        </div>
    </div>
}
else
{
    <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 p-6 rounded-lg text-center shadow-sm">
        <h3 class="font-bold text-lg mb-2">No Data Available</h3>
        <p class="text-sm">Please sync your WebUntis timetable to see your remaining days and lessons.</p>
    </div>
}

@code {
    private bool loading = true;
    private CalculationResult? result;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user != null && !string.IsNullOrEmpty(user.Username))
            {
                result = await CalculationService.CalculateRemainingTimeAsync(user.Username);
            }
        }
        catch 
        {
            // Fail gracefully if calculation fails
            result = null;
        }
        finally
        {
            loading = false;
        }
    }
}
