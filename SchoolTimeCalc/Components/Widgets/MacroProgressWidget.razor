@using SchoolTimeCalc.Models
@using SchoolTimeCalc.Services
@inject ICalculationService CalculationService
@inject MockAuthService AuthService
@rendermode InteractiveServer

@if (loading)
{
    <div class="animate-pulse bg-gray-200 rounded-lg h-32 w-full"></div>
}
else if (result != null && result.TotalSchoolDaysYear > 0)
{
    var daysPercentage = Math.Round((double)result.CompletedSchoolDays / result.TotalSchoolDaysYear * 100, 1);
    var lessonsPercentage = result.TotalLessonsYear > 0 ? Math.Round((double)result.CompletedLessons / result.TotalLessonsYear * 100, 1) : 0;

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
        <!-- Days Progress -->
        <div class="bg-blue-50 p-6 rounded-xl shadow-sm border border-blue-100">
            <div class="flex justify-between items-end mb-2">
                <span class="text-blue-800 text-sm font-bold uppercase tracking-wider">School Days</span>
                <span class="text-blue-900 font-black">@result.CompletedSchoolDays / @result.TotalSchoolDaysYear</span>
            </div>
            
            <div class="w-full bg-blue-200 rounded-full h-4 mb-2">
                <div class="bg-blue-600 h-4 rounded-full" style="width: @daysPercentage%"></div>
            </div>
            
            <div class="flex justify-between text-xs text-blue-700">
                <span>@daysPercentage% Completed</span>
                <span class="font-bold">@result.TotalRemainingDays remaining</span>
            </div>
        </div>

        <!-- Lessons Progress -->
        <div class="bg-indigo-50 p-6 rounded-xl shadow-sm border border-indigo-100">
            <div class="flex justify-between items-end mb-2">
                <span class="text-indigo-800 text-sm font-bold uppercase tracking-wider">Lessons</span>
                <span class="text-indigo-900 font-black">@result.CompletedLessons / @result.TotalLessonsYear</span>
            </div>
            
            <div class="w-full bg-indigo-200 rounded-full h-4 mb-2">
                <div class="bg-indigo-600 h-4 rounded-full" style="width: @lessonsPercentage%"></div>
            </div>
            
            <div class="flex justify-between text-xs text-indigo-700">
                <span>@lessonsPercentage% Completed</span>
                <span class="font-bold">@result.TotalRemainingLessons remaining</span>
            </div>
        </div>
    </div>
}
else
{
    <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 p-6 rounded-lg text-center shadow-sm">
        <h3 class="font-bold text-lg mb-2">No Data Available</h3>
        <p class="text-sm">Please sync your WebUntis timetable to see your progress.</p>
    </div>
}

@code {
    private bool loading = true;
    private CalculationResult? result;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            var user = await AuthService.GetCurrentUserAsync();
            if (user != null && !string.IsNullOrEmpty(user.Username))
            {
                result = await CalculationService.CalculateRemainingTimeAsync(user.Username);
            }
        }
        catch 
        {
            // Fail gracefully if calculation fails
            result = null;
        }
        finally
        {
            loading = false;
        }
    }
}
