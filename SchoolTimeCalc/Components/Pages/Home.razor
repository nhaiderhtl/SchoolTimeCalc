@page "/"
@using SchoolTimeCalc.Services
@using SchoolTimeCalc.Data
@using SchoolTimeCalc.Models
@using Microsoft.EntityFrameworkCore
@inject MockAuthService AuthService
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject CalculationEngine CalculationEngine
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<h1 class="text-3xl font-bold mb-6 text-gray-800">Welcome to SchoolTimeCalc</h1>

@if (loading)
{
    <p class="text-gray-600">Loading...</p>
}
else
{
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <h2 class="text-xl font-bold mb-4 text-gray-800">Location Settings</h2>
            <p class="text-gray-700 mb-4">Your selected state is: <strong>@user?.Bundesland</strong></p>
            <a href="settings" class="text-blue-600 hover:text-blue-800 font-medium hover:underline">Change State</a>
        </div>

        <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
            <h2 class="text-xl font-bold mb-4 text-gray-800">WebUntis Connection</h2>
            @if (hasWebUntisData)
            {
                <div class="flex items-center text-green-700 mb-4">
                    <svg class="h-6 w-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span class="font-bold">Timetable Synced Successfully</span>
                </div>
                <p class="text-gray-700 mb-2">School: <strong>@webUntisData?.SchoolName</strong></p>
                <p class="text-gray-600 text-sm mb-4">Data length: @webUntisData?.SubjectsJson?.Length characters</p>
                <p class="text-gray-700 mb-4 font-semibold">Days Remaining (excluding holidays): @remainingDays</p>
                <a href="webuntis-login" class="text-blue-600 hover:text-blue-800 font-medium hover:underline text-sm">Resync Timetable</a>
            }
            else
            {
                <p class="text-gray-700 mb-4">You have not connected your WebUntis account yet. Link it to view your personalized schedule.</p>
                <button @onclick='() => NavigationManager.NavigateTo("webuntis-login")' class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline">
                    Connect WebUntis Account
                </button>
            }
        </div>
    </div>
}

@code {
    private bool loading = true;
    private SchoolTimeCalc.Models.ApplicationUser? user;
    private WebUntisData? webUntisData;
    private bool hasWebUntisData = false;
    private int remainingDays = 0;

    protected override async Task OnInitializedAsync()
    {
        user = await AuthService.GetCurrentUserAsync();
        if (string.IsNullOrEmpty(user.Bundesland))
        {
            NavigationManager.NavigateTo("settings");
        }
        else
        {
            webUntisData = await DbContext.WebUntisData.FirstOrDefaultAsync(d => d.ApplicationUserId == user.Id);
            hasWebUntisData = webUntisData != null && !string.IsNullOrEmpty(webUntisData.SchoolName);
            if (hasWebUntisData)
            {
                remainingDays = await CalculationEngine.CalculateRemainingSchoolDaysAsync(user.Id);
            }
            loading = false;
        }
    }
}
